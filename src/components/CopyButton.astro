---
interface Props {
  text: string
  labelCopy: string
  labelDone: string
  size?: 'sm' | 'md'
  class?: string
}

const { text, labelCopy, labelDone, size = 'md', class: className } = Astro.props
const classes = ['copy-btn', size === 'sm' ? 'copy-btn-sm' : '', className ?? '']
  .filter(Boolean)
  .join(' ')
---

<button
  type="button"
  class={classes}
  data-clipboard={text}
  data-label-copy={labelCopy}
  data-label-done={labelDone}
  aria-label={labelCopy}
>
  <span class="inner">
    <span class="state idle">
      <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="4.5" y="4.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
        <path d="M3 11V3.5C3 2.67 3.67 2 4.5 2H11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
      </svg>
      <span>{labelCopy}</span>
    </span>
    <span class="state done">
      <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8.5L6.5 12L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <span>{labelDone}</span>
    </span>
  </span>
</button>

<script>
  const DONE_MS = 1600

  async function copy(text: string) {
    try {
      await navigator.clipboard.writeText(text)
    } catch {
      /* Clipboard API blocked — no fallback needed for modern HTTPS contexts. */
    }
  }

  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement | null
    if (!target) return
    const btn = target.closest<HTMLButtonElement>('.copy-btn')
    if (!btn) return
    const text = btn.dataset.clipboard ?? ''
    const labelCopy = btn.dataset.labelCopy ?? 'Copy'
    const labelDone = btn.dataset.labelDone ?? 'Copied'
    await copy(text)
    btn.classList.add('is-done')
    btn.setAttribute('aria-label', labelDone)
    const prev = (btn as HTMLElement & { _t?: number })._t
    if (prev) window.clearTimeout(prev)
    ;(btn as HTMLElement & { _t?: number })._t = window.setTimeout(() => {
      btn.classList.remove('is-done')
      btn.setAttribute('aria-label', labelCopy)
    }, DONE_MS)
  })
</script>

<style>
  .copy-btn {
    flex-shrink: 0;
    align-self: center;
    margin: 6px 6px 6px 0;
    height: 30px;
    padding: 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--bg);
    border: none;
    border-radius: var(--rad-pill);
    display: inline-grid;
    place-items: center;
    transition: background 0.15s;
    cursor: pointer;
  }
  .copy-btn:hover {
    background: var(--accent);
    color: #fff;
  }
  :root[data-theme='dark'] .copy-btn:hover {
    color: var(--bg);
  }
  .copy-btn.is-done {
    background: var(--ok);
  }
  :root[data-theme='dark'] .copy-btn.is-done {
    color: var(--bg);
  }

  .copy-btn-sm {
    margin: 4px 4px 4px 0;
    height: 24px;
    padding: 0 12px;
    font-size: 10px;
  }

  .inner {
    display: grid;
    grid-template-areas: 'stack';
    align-items: center;
    justify-items: center;
  }
  .state {
    grid-area: stack;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .done {
    visibility: hidden;
  }
  .copy-btn.is-done .idle {
    visibility: hidden;
  }
  .copy-btn.is-done .done {
    visibility: visible;
  }
</style>
