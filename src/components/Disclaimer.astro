---
import type { ShellTranslation } from '../types'

interface Props {
  t: ShellTranslation
}

const { t } = Astro.props
---

<section class="disclaimer" id="disclaimer">
  <div class="container">
    <div class="inner">
      <div class="warn-mark" aria-hidden="true"><span>§</span></div>
      <div>
        <div class="tag">⚠ {t.disclaimer.tag}</div>
        <h3>{t.disclaimer.title}</h3>
        <p>{t.disclaimer.body}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .disclaimer {
    padding: 80px 0;
    background: var(--bg-2);
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 600px) {
    .disclaimer {
      padding: 64px 0;
    }
  }
  .inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 960px) {
    .inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .warn-mark {
    width: 120px;
    height: 120px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: 72px;
    color: var(--accent);
    font-style: italic;
    line-height: 1;
    position: relative;
  }
  @media (max-width: 960px) {
    .warn-mark {
      width: 80px;
      height: 80px;
      font-size: 48px;
    }
  }
  .warn-mark::after {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px dashed var(--accent);
    border-radius: 50%;
    opacity: 0.4;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 12px 0 18px;
    text-wrap: balance;
  }
  p {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
    max-width: 68ch;
    margin: 0;
    text-wrap: pretty;
  }
</style>
